# Regula AI — Required Environment Variables
# Copy this file to .env and fill in the values.

# PostgreSQL database (Neon serverless)
# The owner connects via the database card, which injects this into the sandbox.
DATABASE_URL=postgresql://user:password@host/database

# Redis (Upstash) — Required for BullMQ job queues
# The owner connects via the Redis card, which injects this into the sandbox.
# Without this, document processing will be limited to text extraction only.
REDIS_URL=redis://user:password@host:port

# OpenAI API key — Required for semantic rule evaluation (Phase 2)
# Not needed for Phase 1 (text extraction works without it)
OPENAI_API_KEY=sk-...

# File upload directory — where uploaded files are stored on disk
# Default: ./data/uploads
UPLOAD_DIR=./data/uploads

# Stripe billing integration
# Required for subscription payments. Obtain from the Stripe Dashboard.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PROFESSIONAL_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# Email provider (Resend)
# When set (starts with "re_"), transactional and digest emails are sent
# via the Resend API. When not set, emails are logged to data/email-log.json.
EMAIL_API_KEY=re_...
# Sender address for outgoing emails (e.g. "Regula AI <noreply@regula.ai>")
EMAIL_FROM=Regula AI <noreply@regula.ai>
